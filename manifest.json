{
    "name": "Only Philly Sports",
    "version": "0.5.1.5",
    "manifest_version": 3,
    "description": "Get times and scores for today's Philadelphia sports games.",
    "options_page": "src/settings.html",
    "icons": {
        "16": "icons/logo.png"
    },
    "permissions": ["storage"],
    "action": {
        "default_popup": "src/popup.html"
    },
    "background": {
        "service_worker": "scripts/background.js"
    }
}
